# -------------------------------------------------------------------------
SHAPEFILE_1_DEF Transit_Bus_Routes   shapefile_type               shapefile_line   GLOBALID                     varchar(38)   ROUTE_NUM                    long   CLASS                        varchar(20)   TITLE                        varchar(50)   SOURCE                       varchar(12)   SACC                         varchar(2)   SDATE                        date   DATE_ACT                     date   DATE_REV                     date   WEEKDAY                      varchar(1)   PEAK                         varchar(1)   WEEKEND                      varchar(1)   ROUTE_ALPA                   varchar(2)   ROUTE_FULL                   varchar(5)
# -------------------------------------------------------------------------

FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE SHAPEFILE SHAPEFILE_1::Transit_Bus_Routes multi_reader_keyword,$(DATASET_KEYWORD_SHAPEFILE_1) TO FME_GENERIC ::Transit_Bus_Routes ALIAS_GEOMETRY    ROUTE CSV2 CSV2_1::CSV multi_reader_keyword,$(DATASET_KEYWORD_CSV2_1) TO FME_GENERIC ::CSV ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
SHAPEFILE_1_MERGE_DEF SHAPEFILE_1::Transit_Bus_Routes EXACT Transit_Bus_Routes
CSV2_1_MERGE_DEF CSV2_1::CSV EXACT CSV DEFLINE fme_attribute_reading,defined,Route_Number,varchar<openparen>4<closeparen>,Ridership_Total,uint32,Route_Hour,real32,Route_Date,varchar<openparen>21<closeparen>
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "Transit_Bus_Routes_SHAPEFILE_1 Splitter"    INPUT FEATURE_TYPE Transit_Bus_Routes    OUTPUT FEATURE_TYPE Transit_Bus_Routes_SHAPEFILE_1
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "CSV_CSV2_1 Splitter"    INPUT FEATURE_TYPE CSV    OUTPUT FEATURE_TYPE CSV_CSV2_1
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { Tester }    INPUT  FEATURE_TYPE CSV_CSV2_1    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>Route_Date<closeparen>,Tester)" = 1<solidus>23<solidus>2026<space>10:00:00<space>AM ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>Route_Hour<closeparen>,Tester)" = 13 ENCODED }    BOOLEAN_OPERATOR { COMPOSITE }    COMPOSITE_TEST_EXPR { "1 AND 2" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE Tester_PASSED         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} FeatureJoinerFactory    FACTORY_NAME { FeatureJoiner }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT LEFT FEATURE_TYPE Transit_Bus_Routes_SHAPEFILE_1    INPUT RIGHT FEATURE_TYPE Tester_PASSED    JOIN_MODE { Inner }    JOIN_KEYS { ROUTE_FULL Route_Number AUTO }    ATTR_CONFLICT_RES { USE_LEFT }    PRESERVE_VALUES_FROM_UNJOINED_FEATURES { YES }    GEOMETRY_HANDLING { USE_LEFT }    OUTPUT { JOINED FEATURE_TYPE FeatureJoiner_JOINED        }    OUTPUT { <REJECTED> FEATURE_TYPE FeatureJoiner_<REJECTED>        }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME FeatureJoiner_<Rejected> INPUT FEATURE_TYPE FeatureJoiner_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, FeatureJoiner<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Log<space>and<space>Troubleshoot<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
FACTORY_DEF {*} ClassifierFactory    FACTORY_NAME { Classifier }    INPUT  FEATURE_TYPE FeatureJoiner_JOINED    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT_VALUE { @EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>Ridership_Total<closeparen>,Classifier) }    METHOD { NATURAL }    NUM_CLASSES { 3 }    CLASS_ATTR { _class }    OUTPUT { CLASSIFIED FEATURE_TYPE Classifier_CLASSIFIED          }    OUTPUT { <REJECTED> FEATURE_TYPE Classifier_<REJECTED>         }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME Classifier_<Rejected> INPUT FEATURE_TYPE Classifier_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, Classifier<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Log<space>and<space>Troubleshoot<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
FACTORY_DEF {*} SortFactory    FACTORY_NAME { Sorter }    INPUT  FEATURE_TYPE Classifier_CLASSIFIED    SORT_ALPHA_AS_UTF8 { YES }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    SORT_BY { _class NUMERIC ASCENDING NON_VALUES_AFTER_VALUES }    OUTPUT { SORTED FEATURE_TYPE Sorter_SORTED          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { AttributeManager }    INPUT  FEATURE_TYPE Sorter_SORTED    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ACTION_COLUMN 4    DEF_VAL_COLUMN 2    NUM_OF_COLUMNS 5    MISSING_INPUT_ATTR_HANDLING RENAME_SET_VALUE REMOVE    ATTR_ACTION { "ROUTE_FULL" "Route_Identifier" "" "varchar<openparen>5<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "TITLE" "Route_Title" "" "varchar<openparen>50<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "Route_Number" "Route_Number" "" "varchar<openparen>4<closeparen>" "REMOVE" }      ATTR_ACTION { "Ridership_Total" "Ridership_Total" "" "uint32" "REMOVE" }      ATTR_ACTION { "Route_Hour" "Route_Hour" "" "real32" "NO_OP" }      ATTR_ACTION { "Route_Date" "Route_Date" "<at>DateTimeFormat<openparen><at>DateTimeParse<openparen><at>Value<openparen>Route_Date<closeparen><comma>%m<solidus>%d<solidus>%Y<space>%H:%M<closeparen><comma>%m<solidus>%d<solidus>%Y<space>%I:%M:%S<space>%p<closeparen>" "varchar<openparen>21<closeparen>" "SET_TO" }      ATTR_ACTION { "" "Ridership_Classification" "FME_CONDITIONAL:DEFAULT_VALUE'High'BOOL_OP;OR;COMPOSITE_TEST;1;TEST <at>Value<openparen>_class<closeparen> = 0'Low'BOOL_OP;OR;COMPOSITE_TEST;1;TEST <at>Value<openparen>_class<closeparen> = 1'Medium'FME_NUM_CONDITIONS3___" "varchar<openparen>200<closeparen>" "SET_TO" }      ATTR_ACTION { "_class" "_class" "" "uint32" "NO_OP" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeManager_OUTPUT        }
# -------------------------------------------------------------------------

FACTORY_DEF * RoutingFactory FACTORY_NAME "Destination Feature Type Routing Correlator"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE FME_GENERIC AttributeManager_OUTPUT TO GEOJSON __GO_TO_FINAL_OUTPUT_ROUTER__ multi_writer_id,0,<at>SupplyAttributes<openparen>ENCODED<comma>__wb_out_feat_type__<comma>RouteJan23_1pm_Classified<closeparen> COORDINATE_SYSTEM EPSG:3857 GEOMETRY   FEATURE_TYPE_ATTRIBUTE __wb_out_feat_type__   OUTPUT ROUTED FEATURE_TYPE *    OUTPUT NOT_ROUTED FEATURE_TYPE __nuke_me__ @Tcl2("FME_StatMessage 818059 [FME_GetAttribute fme_template_feature_type] 818060 818061 fme_warn")
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory   FACTORY_NAME "Final Output Nuker"   INPUT FEATURE_TYPE __nuke_me__

