FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   MULTI_READER_KEYWORD $(DATASET_KEYWORD_SAFE.ESRI-AGOL.ARCGISFEATURESERVICE_1)   INPUT FEATURE_TYPE *    ROUTE SAFE.ESRI-AGOL.ARCGISFEATURESERVICE "SAFE.ESRI-AGOL.ARCGISFEATURESERVICE_1::Sites for First Location" multi_reader_keyword,$(DATASET_KEYWORD_SAFE.ESRI-AGOL.ARCGISFEATURESERVICE_1) TO FME_GENERIC "::Sites for First Location" ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
SAFE.ESRI-AGOL.ARCGISFEATURESERVICE_1_MERGE_DEF "SAFE.ESRI-AGOL.ARCGISFEATURESERVICE_1::Sites for First Location" EXACT Sites<space>for<space>First<space>Location DEFLINE arcgisfeatureservice_type,arcgisfeatureservice_point,arcgis_input_geometry,,arcgis_true_curve,YES,arcgis_spatial_relationship,esriSpatialRelIntersects,arcgis_distance,,arcgis_input_geometry_type,esriGeometryEnvelope,arcgis_sql_where_clause,,arcgis_units,esriSRUnit_Meter,fme_attribute_reading,defined,OBJECTID,OID,UniqNum,SmallInteger,Description,String<openparen>50<closeparen>
